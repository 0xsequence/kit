{
  "name": "@0xsequence/kit-wallet",
  "version": "4.6.3",
  "description": "Wallet UI for Sequence Kit",
  "repository": "https://github.com/0xsequence/kit/tree/master/packages/wallet",
  "author": "Horizon Blockchain Games",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "build:clean": "rimraf -g ./dist",
    "dev": "tsc --watch --module es2022 --declaration --declarationMap --outDir dist/esm/ --declarationDir dist/types/",
    "test": "echo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.0.7",
    "dayjs": "^1.11.11",
    "fuse.js": "^6.6.2",
    "qrcode.react": "^4.0.1",
    "react-copy-to-clipboard": "^5.1.0"
  },
  "peerDependencies": {
    "@0xsequence/design-system": ">= 2.0.1",
    "@0xsequence/kit": "workspace:*",
    "@0xsequence/api": ">= 2.2.4",
    "@0xsequence/indexer": ">= 2.2.4",
    "@0xsequence/metadata": ">= 2.2.4",
    "@0xsequence/network": ">= 2.2.4",
    "@tanstack/react-query": ">= 5.0.0",
    "ethers": ">= 6.13.0",
    "motion": ">= 12",
    "wagmi": "^2.13.3",
    "viem": ">= 2.0.0"
  },
  "devDependencies": {
    "@0xsequence/design-system": "^2.0.1",
    "@0xsequence/kit": "workspace:*",
    "@types/react-copy-to-clipboard": "^5.0.7",
    "ethers": "^6.13.0",
    "motion": "^12.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "wagmi": "^2.14.11"
  }
}
